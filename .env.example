# Supabase — get these from your project's API settings page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Direct DB connection — for running migrations locally via psql (session mode pooler)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
